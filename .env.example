# ─── Supabase setup ───────────────────────────────────────────────────────────
# 1. Create a project at https://supabase.com
# 2. Dashboard → SQL → run the full script in: supabase/schema.sql
# 3. Dashboard → Storage → create public bucket named: avatars
# 4. Dashboard → Authentication → Providers → Email → turn OFF "Confirm email"
#    (required for instant sign-up without checking inbox)
# 5. Dashboard → Project Settings → API → copy URL + anon key below
# 6. Copy this file to .env and restart: npx expo start -c

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Use either the legacy "anon" JWT (eyJ…) or the newer publishable key (sb_publishable_…)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key_here
